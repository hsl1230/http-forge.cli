{
  "name": "@http-forge/cli",
  "version": "0.2.11",
  "description": "Standalone HTTP Forge launcher and Postman alternative for UI mode, API testing, CI/CD, and MCP server automation",
  "main": "dist/index.js",
  "bin": {
    "http-forge": "dist/cli.js"
  },
  "files": [
    "dist/**",
    "scripts/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "http-forge",
    "http forge",
    "http",
    "api",
    "testing",
    "api testing",
    "postman",
    "postman alternative",
    "openapi",
    "graphql",
    "automation",
    "ci",
    "cd",
    "mcp",
    "mcp server",
    "cli",
    "api cli",
    "postman cli",
    "postman cli alternative",
    "openapi cli",
    "junit",
    "generate",
    "codegen",
    "standalone launcher",
    "api client ui",
    "desktop api client",
    "launcher",
    "vscode"
  ],
  "author": "Henry Huang",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@http-forge/codegen": "^0.1.6",
    "@http-forge/core": "^0.6.11"
  },
  "optionalDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.0.0",
    "@google-cloud/secret-manager": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
